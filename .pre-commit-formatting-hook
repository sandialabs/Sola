#!/usr/bin/env bash

BoldBlack='\033[1;30m'    # Bold black
OnGreen='\033[42m'        # Green background
OnRed='\033[41m'          # Red background
ColorOff='\033[0m'        # Text Reset

LOGFILE=".formatter_changes.txt"


function check_result() {
    # Exit with a failure code if the last command failed.
    if [[ $? -ne 0 ]]; then
        echo -e "${ColorOff}${BoldBlack}${OnRed}failed!${ColorOff}"
        echo -e "\nFormatter made changes, COMMIT ABORTED\n"
        if [[ -e ${LOGFILE} ]]; then
            echo -e "Formatter log\n-------------"
            cat ${LOGFILE}
            rm ${LOGFILE}
            echo ""
        fi
        exit 1
    fi
    echo -e "${ColorOff}${BoldBlack}${OnGreen}passed!${ColorOff}"
}


# Check the formatter is installed.
if ! command -v mh_style &> /dev/null; then
    echo "mh_style not be found, run 'make install'"
    exit 1
fi

echo -n "Checking source code......................."

# Remove files generated by AdiGator.
find . -type d -name "AdiGator_Files" | xargs rm -rf

# Run the formatter for the source code.
mh_style --fix --brief &> ${LOGFILE}
check_result
rm ${LOGFILE}

echo -en "Checking documentation code blocks........."

# Run the formatter for the documentation.
cd docs
python format_code_blocks.py
check_result

exit 0
